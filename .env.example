# AgendaFlow — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Database ────────────────────────────────────────────────────
POSTGRES_ROOT_PASSWORD=replace_with_secure_password
APP_DB_PASSWORD=replace_with_secure_password
MIGRATOR_DB_PASSWORD=replace_with_secure_password

# ── API ─────────────────────────────────────────────────────────
# Connection string for the application (non-owner role)
# ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=agendaflow;Username=agendaflow_app;Password=CHANGE_ME

# ASPNETCORE_ENVIRONMENT=Production

# ── Email ────────────────────────────────────────────────────────
# Development: Mailpit (port 1025, no auth)
# Production: configure a real SMTP provider via env vars
# Email__Host=smtp.example.com
# Email__Port=587
# Email__UseSsl=true
# Email__Username=user@example.com
# Email__Password=CHANGE_ME
# Email__SenderEmail=noreply@yourdomain.com
# Email__SenderName=AgendaFlow

# ── CORS ─────────────────────────────────────────────────────────
# Cors__AllowedOrigins__0=https://yourdomain.com

# ── Data protection (ASP.NET Core) ──────────────────────────────
# For production: persist keys to a volume or secrets manager
# DataProtection__KeysPath=/keys
